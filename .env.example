# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored - never commit real keys.
#
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
# Per the Tech Stack doc: the OAuth Client ID is not a secret and is meant
# to be public. The Gemini and Twelve Data keys ARE visible in the bundle too
# (no backend to hide them behind) - that's a documented, accepted trade-off,
# not an oversight. Never enable billing on the Google Cloud project.

VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GEMINI_API_KEY=
VITE_TWELVE_DATA_API_KEY=
